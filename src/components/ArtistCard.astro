---
const { kunstner } = Astro.props;
---

<div class="card">
  <img 
  src={
    kunstner.kunstner_billede
      ? `/images/${kunstner.kunstner_billede}`
      : "https://picsum.photos/600/400"
  } 
  alt={kunstner.kunstner_navn} 
/>

  <div class="text">
    <p>{kunstner.om_kunstneren}</p>

    <div class="meta">
      {kunstner.spille_dato_tid || "Dag - Tid - Scene"}
    </div>
  </div>
</div>

<style>

.card {
  width: 80%;
  margin: 0 auto;

  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  background: #a33a00;
  color: white;
  padding: 20px;
  border-radius: 20px;
}

img {
  width: 100%;
  height: auto%;
  object-fit: cover;
  border-radius: 8px;
  background: #ccc;
}

.text {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  font-size: 0.9rem;
  line-height: 1.2rem;
}

.meta {
  margin-top: 20px;
  font-weight: bold;
  font-size: 1rem;
  letter-spacing: 0.2rem;
}
</style>